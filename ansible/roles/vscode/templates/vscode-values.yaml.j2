existingSecret: vscode-auth
ingress:
  enabled: true
  hosts:
    - host: "vscode.{{ ingress_domain }}"
      paths:
        - /
  ingressClassName: traefik
extraVolumeMounts:
  - name: extra-volume
    mountPath: /mnt/volume
    readOnly: true
    hostPath: "{{ role_path }}/files/vscode"
extraInitContainers: |
  - name: customization
    image: {{ '{{' }} .Values.image.repository {{ '}}' }}:{{ '{{' }}  .Values.image.tag {{ '}}' }}
    imagePullPolicy: IfNotPresent
    env:
      - name: SERVICE_URL
        value: https://open-vsx.org/vscode/gallery
      - name: ITEM_URL
        value: https://open-vsx.org/vscode/item
    command:
      - sh
      - -c
      - |
        code-server --install-extension /mnt/volume/extensions/dynatrace.dynatrace-debugging-extension-2.3.0.vsix
    volumeMounts:
      - name: data
        mountPath: /home/coder
      - name: extra-volume
        mountPath: /mnt/volume